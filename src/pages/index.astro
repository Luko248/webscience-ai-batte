---
import Layout from '../layouts/Layout.astro';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const pages = [
  { slug: 'festival-task',    title: 'Festival Task',    description: 'Festival management' },
  { slug: 'encyclopedy-task', title: 'Encyclopedy Task', description: 'Encyclopedia research' },
];
---

<Layout title="Home — Webscience AI Batte">
  <main class="min-h-screen flex flex-col items-center justify-center px-6 py-20">
    <h1 class="text-5xl font-bold tracking-tight mb-3">Webscience AI Batte</h1>
    <p class="text-slate-500 text-lg mb-14">Select a section to explore</p>

    <div class="grid grid-cols-1 gap-5 sm:grid-cols-2 w-full max-w-2xl">
      {pages.map(({ slug, title, description }) => (
        <a
          href={`${base}/${slug}`}
          class="group flex flex-col items-center justify-center gap-3 rounded-2xl bg-white border border-slate-200 p-10 shadow-sm transition-all hover:shadow-md hover:border-primary hover:-translate-y-0.5"
        >
          <span class="text-sm font-bold uppercase tracking-widest text-primary">{slug.split('-')[0]}</span>
          <span class="text-xl font-semibold text-slate-800 group-hover:text-primary transition-colors">{title}</span>
          <span class="text-xs text-slate-400">{description}</span>
        </a>
      ))}
    </div>
  </main>
</Layout>
