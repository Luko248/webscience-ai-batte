---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Encyclopedy By Gemini">
  <main class="min-h-screen flex flex-col items-center justify-center px-6 py-20">
    <div class="w-full max-w-2xl">
      <a href={import.meta.env.BASE_URL} class="inline-flex items-center gap-1 text-sm text-slate-500 hover:text-primary mb-10 transition-colors">
        ← Back to home
      </a>
      <div class="flex items-center gap-4 mb-6">
        <span class="text-sm font-bold uppercase tracking-widest text-primary">encyclopedy</span>
        <h1 class="text-4xl font-bold">Encyclopedy By Gemini</h1>
      </div>
      <p class="text-slate-500 text-lg leading-relaxed">
        This is the Encyclopedy Task subpage generated by Gemini. Add your content here.
      </p>
    </div>
  </main>
</Layout>
