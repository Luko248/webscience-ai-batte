---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="T-Rex Encyclopedia by Claude">
  <main class="trex-shell">
    <aside class="trex-sidebar">
      <a href={import.meta.env.BASE_URL} class="back-link">← Back to home</a>
      <div class="sidebar-header">
        <span class="eyebrow">encyclopedia</span>
        <h1>Tyrannosaurus rex</h1>
        <p class="lede">An interactive 3D field guide. Hover for a tease, click to fly the camera to that anatomy.</p>
      </div>

      <nav class="parts-list" id="parts-list">
        <button class="part-btn" data-part="overview">
          <span class="part-title">Overview</span>
          <span class="part-meta">Whole skeleton</span>
          <div class="tooltip">
            <strong>The apex predator</strong>
            <span>~12 m long, 8 tonnes. Late Cretaceous (68–66 Mya). Click to reset the view.</span>
          </div>
        </button>

        <button class="part-btn" data-part="teeth">
          <span class="part-title">Teeth</span>
          <span class="part-meta">Banana-shaped daggers</span>
          <div class="tooltip">
            <strong>60 serrated teeth</strong>
            <span>Up to 30 cm long including the root. Bite force estimated at 35,000 N — the strongest of any land animal ever measured.</span>
          </div>
        </button>

        <button class="part-btn" data-part="belly">
          <span class="part-title">Belly</span>
          <span class="part-meta">Gastralia &amp; gut</span>
          <div class="tooltip">
            <strong>Stomach the size of a bathtub</strong>
            <span>Gastralia (belly ribs) braced the abdomen during deep breaths. T. rex could swallow ~70 kg of meat in a single gulp.</span>
          </div>
        </button>

        <button class="part-btn" data-part="tail">
          <span class="part-title">Tail</span>
          <span class="part-meta">Counterweight engine</span>
          <div class="tooltip">
            <strong>Held horizontal, not dragging</strong>
            <span>Powered by the caudofemoralis muscle, the tail balanced the massive head and drove the hind limbs forward at up to 20 km/h.</span>
          </div>
        </button>
      </nav>

      <footer class="sidebar-foot">
        <span>Drag the canvas to orbit · scroll to zoom</span>
      </footer>
    </aside>

    <section class="trex-stage">
      <div id="trex-canvas-wrap"></div>
      <div class="hud" id="hud">
        <span class="hud-label">Now showing</span>
        <span class="hud-value" id="hud-value">Overview</span>
      </div>
      <div class="loading" id="loading">Building T-rex…</div>
    </section>
  </main>

  <style>
    .trex-shell {
      display: grid;
      grid-template-columns: 340px 1fr;
      min-height: 100vh;
      background: radial-gradient(ellipse at top right, #0f172a 0%, #020617 60%, #000 100%);
      color: #e2e8f0;
    }

    .trex-sidebar {
      padding: 28px 24px 20px;
      border-right: 1px solid rgba(148, 163, 184, 0.15);
      display: flex;
      flex-direction: column;
      gap: 24px;
      background: rgba(2, 6, 23, 0.6);
      backdrop-filter: blur(8px);
      position: relative;
      z-index: 2;
    }

    .back-link {
      color: #94a3b8;
      font-size: 13px;
      text-decoration: none;
      transition: color 0.2s;
      width: fit-content;
    }
    .back-link:hover { color: #20c997; }

    .eyebrow {
      font-size: 11px;
      font-weight: 700;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: #20c997;
    }

    .sidebar-header h1 {
      font-size: 28px;
      font-weight: 800;
      margin: 8px 0 12px;
      letter-spacing: -0.02em;
      font-style: italic;
    }

    .lede {
      color: #94a3b8;
      font-size: 14px;
      line-height: 1.55;
    }

    .parts-list {
      display: flex;
      flex-direction: column;
      gap: 10px;
    }

    .part-btn {
      position: relative;
      text-align: left;
      padding: 14px 16px;
      border-radius: 10px;
      border: 1px solid rgba(148, 163, 184, 0.18);
      background: rgba(15, 23, 42, 0.6);
      color: #e2e8f0;
      cursor: pointer;
      transition: all 0.18s ease;
      display: flex;
      flex-direction: column;
      gap: 3px;
    }
    .part-btn:hover {
      border-color: rgba(32, 201, 151, 0.6);
      background: rgba(32, 201, 151, 0.08);
      transform: translateX(2px);
    }
    .part-btn.is-active {
      border-color: #20c997;
      background: rgba(32, 201, 151, 0.14);
      box-shadow: 0 0 0 1px rgba(32, 201, 151, 0.35), 0 8px 24px -8px rgba(32, 201, 151, 0.4);
    }

    .part-title {
      font-weight: 700;
      font-size: 15px;
    }
    .part-meta {
      font-size: 12px;
      color: #94a3b8;
    }

    .tooltip {
      position: absolute;
      left: calc(100% + 14px);
      top: 50%;
      transform: translateY(-50%) translateX(-6px);
      width: 260px;
      padding: 12px 14px;
      border-radius: 10px;
      background: #0b1220;
      border: 1px solid rgba(32, 201, 151, 0.35);
      box-shadow: 0 20px 50px -10px rgba(0, 0, 0, 0.6);
      opacity: 0;
      pointer-events: none;
      transition: opacity 0.18s ease, transform 0.18s ease;
      z-index: 10;
      display: flex;
      flex-direction: column;
      gap: 4px;
    }
    .tooltip::before {
      content: '';
      position: absolute;
      left: -6px;
      top: 50%;
      width: 10px;
      height: 10px;
      background: #0b1220;
      border-left: 1px solid rgba(32, 201, 151, 0.35);
      border-bottom: 1px solid rgba(32, 201, 151, 0.35);
      transform: translateY(-50%) rotate(45deg);
    }
    .tooltip strong {
      color: #20c997;
      font-size: 13px;
    }
    .tooltip span {
      font-size: 12.5px;
      color: #cbd5e1;
      line-height: 1.5;
    }
    .part-btn:hover .tooltip {
      opacity: 1;
      transform: translateY(-50%) translateX(0);
    }

    .sidebar-foot {
      margin-top: auto;
      color: #64748b;
      font-size: 11.5px;
      letter-spacing: 0.04em;
      border-top: 1px solid rgba(148, 163, 184, 0.12);
      padding-top: 14px;
    }

    .trex-stage {
      position: relative;
      overflow: hidden;
    }
    #trex-canvas-wrap {
      position: absolute;
      inset: 0;
    }
    #trex-canvas-wrap canvas {
      display: block;
      width: 100% !important;
      height: 100% !important;
    }

    .hud {
      position: absolute;
      top: 24px;
      right: 24px;
      padding: 10px 16px;
      border-radius: 10px;
      background: rgba(2, 6, 23, 0.7);
      border: 1px solid rgba(148, 163, 184, 0.2);
      backdrop-filter: blur(6px);
      display: flex;
      flex-direction: column;
      align-items: flex-end;
      gap: 2px;
      pointer-events: none;
    }
    .hud-label {
      font-size: 10px;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: #64748b;
    }
    .hud-value {
      font-size: 16px;
      font-weight: 700;
      color: #20c997;
    }

    .loading {
      position: absolute;
      inset: 0;
      display: flex;
      align-items: center;
      justify-content: center;
      color: #94a3b8;
      font-size: 14px;
      letter-spacing: 0.08em;
      pointer-events: none;
      transition: opacity 0.4s;
    }
    .loading.is-hidden { opacity: 0; }

    @media (max-width: 860px) {
      .trex-shell { grid-template-columns: 1fr; }
      .trex-sidebar { border-right: none; border-bottom: 1px solid rgba(148, 163, 184, 0.15); }
      .tooltip { display: none; }
      .trex-stage { height: 60vh; }
    }
  </style>

  <script type="module">
    import * as THREE from 'https://esm.sh/three@0.160.0';
    import { OrbitControls } from 'https://esm.sh/three@0.160.0/examples/jsm/controls/OrbitControls.js';

    const wrap = document.getElementById('trex-canvas-wrap');
    const hudValue = document.getElementById('hud-value');
    const loading = document.getElementById('loading');

    const scene = new THREE.Scene();
    scene.background = null;
    scene.fog = new THREE.Fog(0x020617, 18, 60);

    const camera = new THREE.PerspectiveCamera(45, 1, 0.1, 200);
    camera.position.set(12, 6, 14);

    const renderer = new THREE.WebGLRenderer({ antialias: true, alpha: true });
    renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
    renderer.shadowMap.enabled = true;
    renderer.shadowMap.type = THREE.PCFSoftShadowMap;
    wrap.appendChild(renderer.domElement);

    const controls = new OrbitControls(camera, renderer.domElement);
    controls.enableDamping = true;
    controls.dampingFactor = 0.08;
    controls.minDistance = 4;
    controls.maxDistance = 30;
    controls.maxPolarAngle = Math.PI * 0.52;

    const hemi = new THREE.HemisphereLight(0x86c5ff, 0x1a1208, 0.55);
    scene.add(hemi);
    const key = new THREE.DirectionalLight(0xffe9c2, 1.4);
    key.position.set(8, 14, 6);
    key.castShadow = true;
    key.shadow.mapSize.set(2048, 2048);
    key.shadow.camera.left = -15;
    key.shadow.camera.right = 15;
    key.shadow.camera.top = 15;
    key.shadow.camera.bottom = -15;
    scene.add(key);
    const rim = new THREE.DirectionalLight(0x20c997, 0.6);
    rim.position.set(-10, 6, -8);
    scene.add(rim);

    const ground = new THREE.Mesh(
      new THREE.CircleGeometry(40, 64),
      new THREE.MeshStandardMaterial({ color: 0x0b1220, roughness: 1, metalness: 0 })
    );
    ground.rotation.x = -Math.PI / 2;
    ground.position.y = -0.01;
    ground.receiveShadow = true;
    scene.add(ground);

    const grid = new THREE.GridHelper(60, 30, 0x1e293b, 0x0f172a);
    scene.add(grid);

    const trex = new THREE.Group();
    scene.add(trex);

    const skinMat = new THREE.MeshStandardMaterial({ color: 0x6b7a3a, roughness: 0.75, metalness: 0.05 });
    const bellyMat = new THREE.MeshStandardMaterial({ color: 0xb39668, roughness: 0.85, metalness: 0.02 });
    const toothMat = new THREE.MeshStandardMaterial({ color: 0xf2efe3, roughness: 0.35, metalness: 0.1 });
    const clawMat = new THREE.MeshStandardMaterial({ color: 0x1a1410, roughness: 0.4, metalness: 0.2 });
    const eyeMat = new THREE.MeshStandardMaterial({ color: 0xffd000, emissive: 0x885500, emissiveIntensity: 0.6, roughness: 0.3 });

    const named = { teeth: new THREE.Group(), belly: new THREE.Group(), tail: new THREE.Group() };
    Object.values(named).forEach((g) => trex.add(g));

    // body
    const body = new THREE.Mesh(new THREE.SphereGeometry(1.6, 32, 24), skinMat);
    body.scale.set(1.0, 0.95, 2.0);
    body.position.set(0, 3.0, 0);
    body.castShadow = true;
    trex.add(body);

    // belly patch
    const belly = new THREE.Mesh(
      new THREE.SphereGeometry(1.45, 32, 24, 0, Math.PI * 2, Math.PI * 0.45, Math.PI * 0.55),
      bellyMat
    );
    belly.scale.set(1.0, 1.0, 2.0);
    belly.position.set(0, 3.0, 0.05);
    belly.castShadow = true;
    named.belly.add(belly);

    // gastralia (belly ribs)
    for (let i = 0; i < 7; i++) {
      const rib = new THREE.Mesh(new THREE.TorusGeometry(0.65, 0.05, 6, 16, Math.PI), bellyMat);
      rib.rotation.z = Math.PI / 2;
      rib.rotation.x = Math.PI;
      rib.position.set(0, 1.85, -1.4 + i * 0.45);
      rib.castShadow = true;
      named.belly.add(rib);
    }

    // neck
    const neck = new THREE.Mesh(new THREE.CylinderGeometry(0.55, 0.85, 1.4, 16), skinMat);
    neck.position.set(0, 3.7, 2.2);
    neck.rotation.x = -Math.PI / 4;
    neck.castShadow = true;
    trex.add(neck);

    // head group
    const headGroup = new THREE.Group();
    headGroup.position.set(0, 4.35, 3.1);
    trex.add(headGroup);

    const skull = new THREE.Mesh(new THREE.BoxGeometry(1.1, 0.95, 1.9), skinMat);
    skull.castShadow = true;
    headGroup.add(skull);

    const snout = new THREE.Mesh(new THREE.BoxGeometry(0.85, 0.7, 0.8), skinMat);
    snout.position.set(0, -0.05, 1.2);
    snout.castShadow = true;
    headGroup.add(snout);

    const jaw = new THREE.Mesh(new THREE.BoxGeometry(0.95, 0.25, 1.6), skinMat);
    jaw.position.set(0, -0.5, 0.4);
    jaw.castShadow = true;
    headGroup.add(jaw);

    const eyeL = new THREE.Mesh(new THREE.SphereGeometry(0.11, 16, 16), eyeMat);
    eyeL.position.set(0.42, 0.25, 0.55);
    headGroup.add(eyeL);
    const eyeR = eyeL.clone();
    eyeR.position.x = -0.42;
    headGroup.add(eyeR);

    // teeth
    const teethGroup = named.teeth;
    headGroup.add(teethGroup);
    const makeTooth = (size = 0.18) => new THREE.Mesh(new THREE.ConeGeometry(0.07, size, 8), toothMat);

    for (let i = 0; i < 10; i++) {
      const t = i / 9;
      const z = -0.4 + t * 1.9;
      const len = 0.16 + 0.18 * Math.sin(t * Math.PI);
      const left = makeTooth(len);
      left.position.set(0.38 - Math.abs(t - 0.5) * 0.08, -0.35, z);
      left.rotation.x = Math.PI;
      left.castShadow = true;
      teethGroup.add(left);
      const right = left.clone();
      right.position.x = -left.position.x;
      teethGroup.add(right);
    }
    for (let i = 0; i < 9; i++) {
      const t = i / 8;
      const z = -0.3 + t * 1.7;
      const len = 0.14 + 0.14 * Math.sin(t * Math.PI);
      const left = makeTooth(len);
      left.position.set(0.36 - Math.abs(t - 0.5) * 0.08, -0.32, z);
      left.castShadow = true;
      teethGroup.add(left);
      const right = left.clone();
      right.position.x = -left.position.x;
      teethGroup.add(right);
    }

    // tail
    const tailGroup = named.tail;
    const segments = 14;
    let prevZ = -1.4;
    let prevR = 1.2;
    for (let i = 0; i < segments; i++) {
      const t = i / (segments - 1);
      const r = prevR * 0.93;
      const segLen = 0.55;
      const seg = new THREE.Mesh(new THREE.CylinderGeometry(r, r * 0.92, segLen, 14), skinMat);
      seg.rotation.x = Math.PI / 2;
      const dropY = -t * 1.4;
      const z = prevZ - segLen;
      seg.position.set(0, 3.0 + dropY * 0.4, z + segLen / 2);
      seg.castShadow = true;
      tailGroup.add(seg);
      prevR = r;
      prevZ = z;
    }

    // legs
    const makeLeg = (xSign) => {
      const grp = new THREE.Group();
      const thigh = new THREE.Mesh(new THREE.CylinderGeometry(0.42, 0.55, 1.6, 14), skinMat);
      thigh.position.set(xSign * 0.7, 2.0, -0.2);
      thigh.rotation.x = 0.2;
      thigh.castShadow = true;
      grp.add(thigh);

      const shin = new THREE.Mesh(new THREE.CylinderGeometry(0.25, 0.32, 1.5, 14), skinMat);
      shin.position.set(xSign * 0.7, 0.9, 0.05);
      shin.rotation.x = -0.15;
      shin.castShadow = true;
      grp.add(shin);

      const foot = new THREE.Mesh(new THREE.BoxGeometry(0.55, 0.18, 1.0), skinMat);
      foot.position.set(xSign * 0.7, 0.18, 0.35);
      foot.castShadow = true;
      grp.add(foot);

      for (let i = -1; i <= 1; i++) {
        const claw = new THREE.Mesh(new THREE.ConeGeometry(0.06, 0.22, 8), clawMat);
        claw.rotation.x = Math.PI / 2;
        claw.position.set(xSign * 0.7 + i * 0.18, 0.12, 0.85);
        claw.castShadow = true;
        grp.add(claw);
      }
      return grp;
    };
    trex.add(makeLeg(1));
    trex.add(makeLeg(-1));

    // tiny arms
    const makeArm = (xSign) => {
      const grp = new THREE.Group();
      const upper = new THREE.Mesh(new THREE.CylinderGeometry(0.13, 0.16, 0.55, 10), skinMat);
      upper.position.set(xSign * 1.0, 3.2, 1.1);
      upper.rotation.z = xSign * 0.6;
      upper.castShadow = true;
      grp.add(upper);
      const fore = new THREE.Mesh(new THREE.CylinderGeometry(0.1, 0.13, 0.45, 10), skinMat);
      fore.position.set(xSign * 1.25, 2.85, 1.25);
      fore.rotation.z = xSign * 0.3;
      fore.castShadow = true;
      grp.add(fore);
      for (let i = 0; i < 2; i++) {
        const claw = new THREE.Mesh(new THREE.ConeGeometry(0.04, 0.16, 8), clawMat);
        claw.position.set(xSign * (1.32 + i * 0.05), 2.62, 1.32);
        claw.rotation.x = Math.PI;
        grp.add(claw);
      }
      return grp;
    };
    trex.add(makeArm(1));
    trex.add(makeArm(-1));

    // ---------- VIEW TARGETS ----------
    const views = {
      overview: { target: new THREE.Vector3(0, 3, 0),   camera: new THREE.Vector3(11, 5.5, 11) },
      teeth:    { target: new THREE.Vector3(0, 4.2, 4.0), camera: new THREE.Vector3(2.5, 4.7, 5.6) },
      belly:    { target: new THREE.Vector3(0, 2.4, 0.2), camera: new THREE.Vector3(0.5, 2.6, 6.2) },
      tail:     { target: new THREE.Vector3(0, 2.6, -5.5), camera: new THREE.Vector3(-5.5, 4.2, -6.5) },
    };

    // tween
    let tween = null;
    const easeInOut = (t) => (t < 0.5 ? 2 * t * t : 1 - Math.pow(-2 * t + 2, 2) / 2);
    function flyTo(view, label) {
      const fromCam = camera.position.clone();
      const fromTar = controls.target.clone();
      const toCam = view.camera.clone();
      const toTar = view.target.clone();
      const dur = 1200;
      const start = performance.now();
      tween = (now) => {
        const t = Math.min(1, (now - start) / dur);
        const k = easeInOut(t);
        camera.position.lerpVectors(fromCam, toCam, k);
        controls.target.lerpVectors(fromTar, toTar, k);
        if (t >= 1) tween = null;
      };
      hudValue.textContent = label;
    }

    // highlight
    function highlight(partKey) {
      ['teeth', 'belly', 'tail'].forEach((k) => {
        named[k].traverse((m) => {
          if (!m.isMesh) return;
          if (!m.userData.baseEmissive) {
            m.userData.baseEmissive = m.material.emissive ? m.material.emissive.clone() : new THREE.Color(0x000000);
          }
          if (m.material.emissive) m.material.emissive.copy(m.userData.baseEmissive);
        });
      });
      if (partKey && partKey !== 'overview' && named[partKey]) {
        named[partKey].traverse((m) => {
          if (m.isMesh && m.material.emissive) {
            m.material.emissive.set(0x20c997).multiplyScalar(0.35);
          }
        });
      }
    }

    const buttons = document.querySelectorAll('.part-btn');
    buttons.forEach((btn) => {
      btn.addEventListener('click', () => {
        const part = btn.dataset.part;
        buttons.forEach((b) => b.classList.toggle('is-active', b === btn));
        flyTo(views[part], btn.querySelector('.part-title').textContent);
        highlight(part);
      });
    });
    document.querySelector('.part-btn[data-part="overview"]').classList.add('is-active');

    function resize() {
      const w = wrap.clientWidth || window.innerWidth - 340;
      const h = wrap.clientHeight || window.innerHeight;
      renderer.setSize(w, h, false);
      camera.aspect = w / h;
      camera.updateProjectionMatrix();
    }
    new ResizeObserver(resize).observe(wrap);
    resize();

    const clock = new THREE.Clock();
    function animate() {
      requestAnimationFrame(animate);
      const t = clock.getElapsedTime();
      trex.position.y = Math.sin(t * 1.2) * 0.04;
      tailGroup.rotation.y = Math.sin(t * 0.6) * 0.04;
      headGroup.rotation.y = Math.sin(t * 0.4) * 0.06;
      if (tween) tween(performance.now());
      controls.update();
      renderer.render(scene, camera);
    }
    animate();

    requestAnimationFrame(() => {
      loading.classList.add('is-hidden');
      setTimeout(() => loading.remove(), 500);
    });
  </script>
</Layout>
